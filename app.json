{
  "expo": {
    "name": "GLOWMAX",
    "slug": "glowmax",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "glowmax",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0C0E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.glowmax.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0C0E"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.glowmax.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "GLOWMAX cần quyền truy cập camera để phân tích khuôn mặt của bạn."
        }
      ],
      "expo-web-browser"
    ]
  }
}
