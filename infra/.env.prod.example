# =============================================================================
# .env.prod.example — Template env vars cho production
# =============================================================================
# Cách dùng:
#   cp .env.prod.example .env.prod
#   chmod 600 .env.prod          ← CHỈ owner (ec2-user) đọc được
#   nano .env.prod               ← điền values thật
#
# KHÔNG commit .env.prod lên git (đã có trong .gitignore)
# File này (.env.prod.example) commit được vì chỉ chứa keys, không có values
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# Password cho Postgres superuser (user 'postgres' trong container)
# Generate: openssl rand -base64 32
DB_SUPERUSER_PASSWORD=CHANGE_ME_strong_random_password

# Password cho app user least-privilege (user 'glowmax_app')
# Tạo user này sau khi Postgres container start lần đầu — xem README section "Database hardening"
# Spring Boot dùng user này (không dùng superuser postgres để chạy app)
DB_APP_PASSWORD=CHANGE_ME_another_strong_password

# Spring Boot datasource — trỏ tới container 'postgres' qua Docker network
# Đã override trong docker-compose.prod.yml: SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/glowmax
# Env var này dùng nếu bạn chạy app ngoài Docker
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/glowmax
# SPRING_DATASOURCE_USERNAME=glowmax_app
# SPRING_DATASOURCE_PASSWORD=    ← set bằng DB_APP_PASSWORD phía trên

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
# Signing key cho HS256 — phải >= 256 bits (32 bytes) cho HS256
# Generate: openssl rand -base64 64
APP_JWT_SECRET=CHANGE_ME_minimum_64_chars_random_string_for_hs256_signing

# Issuer và audience phải khớp với verify logic trong JwtUtil.java
APP_JWT_ISSUER=api.glowmax.codes
APP_JWT_AUDIENCE=glowmax-mobile

# Thời gian sống của access token (giây). 900 = 15 phút
APP_JWT_ACCESS_TOKEN_TTL_SECONDS=900

# -----------------------------------------------------------------------------
# GOOGLE OAUTH
# -----------------------------------------------------------------------------
# Lấy từ Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Client type: Web application
# Authorized redirect URIs: https://api.glowmax.codes/api/v1/auth/oauth/google/callback
APP_GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
APP_GOOGLE_CLIENT_SECRET=CHANGE_ME_google_client_secret

# -----------------------------------------------------------------------------
# APPLE OAUTH (skeleton — enable khi Apple Developer account duyệt)
# -----------------------------------------------------------------------------
# APP_APPLE_CLIENT_ID=codes.glowmax.app
# APP_APPLE_TEAM_ID=XXXXXXXXXX
# APP_APPLE_KEY_ID=XXXXXXXXXX
# APP_APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# -----------------------------------------------------------------------------
# OPENAI
# -----------------------------------------------------------------------------
# Lấy từ platform.openai.com → API Keys
# ROTATE KEY NÀY nếu nghi ngờ bị leak!
APP_OPENAI_API_KEY=sk-CHANGE_ME
APP_OPENAI_BASE_URL=https://api.openai.com

# -----------------------------------------------------------------------------
# AWS S3 (Avatar storage)
# -----------------------------------------------------------------------------
APP_AWS_REGION=ap-southeast-1

# S3 bucket name — tạo trong AWS Console trước khi deploy
# Xem README section "Bước 3 — Tạo S3 bucket"
APP_AWS_S3_BUCKET=glowmax-leaderboard-avatars

# IAM credentials cho app upload S3
# Tạo IAM user 'glowmax-app' với policy chỉ cho PutObject/GetObject vào bucket trên
# Xem README section "S3 IAM policy"
# LƯU Ý: Trên EC2 production nên dùng IAM Instance Profile thay vì access key
# (không cần key này nếu EC2 đã attach instance profile — để trống 2 dòng dưới)
APP_AWS_ACCESS_KEY=CHANGE_ME_or_leave_empty_if_using_instance_profile
APP_AWS_SECRET_KEY=CHANGE_ME_or_leave_empty_if_using_instance_profile

# -----------------------------------------------------------------------------
# SPRING BOOT MISC
# -----------------------------------------------------------------------------
# Active profile — phải là 'prod'
SPRING_PROFILES_ACTIVE=prod

# Server port (Caddy proxy vào port này)
SERVER_PORT=8080

# Tắt Swagger UI / H2 console trên production (đã config trong application.yml)
# Không cần set ở đây nếu application.yml đã handle qua profile

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# Sau khi edit xong:
#   docker compose -f docker-compose.prod.yml up -d
#
# Verify app nhận đúng env:
#   docker exec glowmax-api env | grep APP_JWT_ISSUER
#
# Rotate secret (ví dụ JWT_SECRET):
#   1. Generate secret mới
#   2. Cập nhật .env.prod
#   3. docker compose -f docker-compose.prod.yml up -d api   ← chỉ restart api, không restart postgres
#   4. Tất cả access token cũ bị invalidate ngay → users phải login lại
#      (acceptable vì TTL chỉ 15 phút)
