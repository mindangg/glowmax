# =============================================================================
# DEPENDENCIES
# =============================================================================
node_modules/

# =============================================================================
# FRONTEND (React Native / Expo)
# =============================================================================
.expo/
dist/
web-build/
expo-env.d.ts
.metro-health-check*
.kotlin/
*.orig.*

# Native code generated by Expo prebuild
frontend/ios/
frontend/android/

# =============================================================================
# BACKEND (Spring Boot / Maven)
# =============================================================================
backend/target/
backend/HELP.md
backend/logs/
backend/src/main/resources/application-dev.yml
backend/src/main/resources/application-local.yml

# Maven wrapper JAR phải được commit để CI dùng được
!backend/.mvn/wrapper/maven-wrapper.jar

# =============================================================================
# INFRA (secrets must NEVER be committed)
# =============================================================================
infra/.env.prod
infra/.env.local
infra/secrets/
infra/*.pem
infra/aws-credentials
infra/caddy_data/

# =============================================================================
# ENV FILES (secrets)
# =============================================================================
.env
.env.local
.env*.local
.env.production
.env.prod
!.env.example
!*.env.example

# =============================================================================
# SIGNING / CERTIFICATES
# =============================================================================
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# =============================================================================
# BUILD ARTIFACTS
# =============================================================================
*.class
*.jar
*.tsbuildinfo

# =============================================================================
# IDE / EDITOR
# =============================================================================
.idea/
.vscode/
*.iml
*.swp
.classpath
.project
.settings/

# =============================================================================
# LOGS
# =============================================================================
*.log
logs/
npm-debug.*
yarn-debug.*
yarn-error.*

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
