# ─────────────────────────────────────────────
# Dependencies (matches any subfolder: frontend, backend, infra)
# ─────────────────────────────────────────────
node_modules/

# ─────────────────────────────────────────────
# Frontend (React Native / Expo)
# ─────────────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts
.metro-health-check*

# Native code generated by Expo prebuild
frontend/ios/
frontend/android/

# Native signing
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem
.kotlin/
*.orig.*

# ─────────────────────────────────────────────
# Backend (Spring Boot / Maven)
# ─────────────────────────────────────────────
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/HELP.md
*.class
*.jar
!backend/.mvn/wrapper/maven-wrapper.jar

# Spring Boot runtime
backend/logs/
backend/*.log

# ─────────────────────────────────────────────
# Infra (secrets must NEVER be committed)
# ─────────────────────────────────────────────
infra/.env.prod
infra/.env.local
infra/secrets/
infra/*.pem
infra/aws-credentials

# Caddy data (auto-generated certs)
infra/caddy_data/

# ─────────────────────────────────────────────
# IDE / Editor
# ─────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.swp

# ─────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────
# Debug / Logs
# ─────────────────────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# ─────────────────────────────────────────────
# TypeScript
# ─────────────────────────────────────────────
*.tsbuildinfo

# ─────────────────────────────────────────────
# Local env files (never commit secrets)
# ─────────────────────────────────────────────
.env
.env.local
.env*.local
.env.production
!.env.example
!*.env.example
