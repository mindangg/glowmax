# ════════════════════════════════════════════════════════════════
# Glowmax Backend — env template
# Copy thành .env và điền giá trị thật. KHÔNG commit .env vào git.
# ════════════════════════════════════════════════════════════════

# ─── Active profile ─────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ─── Database ───────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/glowmax
DB_USERNAME=glowmax
DB_PASSWORD=changeme

# ─── JWT ────────────────────────────────────────────────────────
# Generate bằng: openssl rand -base64 64
JWT_SECRET=replace-me-with-random-64-byte-base64-string
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7
JWT_ISSUER=api.glowmax.codes
JWT_AUDIENCE=glowmax-mobile

# ─── OAuth: Google ──────────────────────────────────────────────
# Lấy từ Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OAuth: Apple (skeleton — bật khi Apple Dev acc duyệt) ──────
# Service ID + Key ID + Team ID + Private key path
APPLE_CLIENT_ID=com.glowmax.app
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=/path/to/AuthKey_XXXXX.p8

# ─── OpenAI (analyze-face) ──────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── AWS S3 ─────────────────────────────────────────────────────
# Khi chạy trên EC2: dùng IAM instance role thay access key (để trống 2 var dưới)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_AVATAR_BUCKET=glowmax-leaderboard-avatars
S3_AVATAR_PUBLIC_URL_PREFIX=https://glowmax-leaderboard-avatars.s3.ap-southeast-1.amazonaws.com

# ─── Sentry ─────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Server ─────────────────────────────────────────────────────
SERVER_PORT=8080

# ─── CORS (RN app) ──────────────────────────────────────────────
# Dev: allow Expo dev URLs; Prod: chỉ allow custom scheme
CORS_ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:19000,glowmax://
