# =============================================================================
# .env.example — Frontend environment variables
# =============================================================================

# ── Spring Boot Backend URL ──────────────────────────────────────────────────
# Dev local: backend chạy trên máy (./mvnw spring-boot:run)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# Production: uncomment khi deploy (đổi domain thật)
# EXPO_PUBLIC_API_BASE_URL=https://api.glowmax.codes

# ── Google OAuth Client IDs ──────────────────────────────────────────────────
# Tạo tại: console.cloud.google.com → APIs & Services → Credentials
# iOS: client type "iOS", Android: client type "Android"
# KHÔNG dùng "Web application" client ID cho mobile
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=CHANGE_ME.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=CHANGE_ME.apps.googleusercontent.com

# ── RevenueCat ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxx
